# ─── Required ───
DATABASE_URL=postgresql://user:pass@host:5432/dbname
HF_REPO_ID=zeroday01/ipl_prediction_engine
HF_TOKEN=hf_your_token_here

# ─── Redis (set REDIS_ENABLED=false for dev without Redis) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ENABLED=true

# ─── Optional: OpenAI for Agent LLM mode ───
OPENAI_API_KEY=

# ─── Server ───
APP_HOST=0.0.0.0
APP_PORT=7860
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:7860

# ─── Training ───
MAX_TRAIN_MATCHES=0
